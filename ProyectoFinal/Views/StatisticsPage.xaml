<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.Views.StatisticsPage"
             Title="Estadísticas">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Estadísticas" Style="{StaticResource TitleStyle}"/>

            <!-- Summary Cards -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="10">

                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#5B4FCF" Padding="15"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Total Libros" TextColor="White" FontSize="12"/>
                        <Label Text="{Binding TotalBooks}" TextColor="White" FontSize="28" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#E53935" Padding="15"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Páginas Leídas" TextColor="White" FontSize="12"/>
                        <Label Text="{Binding TotalPages}" TextColor="White" FontSize="28" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#43A047" Padding="15"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Libros Leídos" TextColor="White" FontSize="12"/>
                        <Label Text="{Binding BooksRead}" TextColor="White" FontSize="28" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#FB8C00" Padding="15"
                        StrokeShape="RoundRectangle 10" Stroke="Transparent">
                    <VerticalStackLayout>
                        <Label Text="Pendientes" TextColor="White" FontSize="12"/>
                        <Label Text="{Binding BooksPending}" TextColor="White" FontSize="28" FontAttributes="Bold"/>
                    </VerticalStackLayout>
                </Border>

            </Grid>

            <!-- Calculated properties -->
            <Border Style="{StaticResource CardStyle}">
                <VerticalStackLayout Spacing="5">
                    <Label Text="{Binding BooksCount}" Style="{StaticResource SubtitleStyle}"/>
                    <Label Text="{Binding ReadPercentage}" Style="{StaticResource SubtitleStyle}"/>
                    <Label Text="{Binding AveragePages, StringFormat='Promedio: {0} páginas'}" Style="{StaticResource CaptionStyle}"/>
                </VerticalStackLayout>
            </Border>

            <!-- Most read category -->
            <Border BackgroundColor="{StaticResource Surface}" Padding="15"
                    StrokeShape="RoundRectangle 10" Stroke="Transparent">
                <HorizontalStackLayout Spacing="10">
                    <Label Text="Categoría más leída:" Style="{StaticResource SubtitleStyle}" VerticalOptions="Center"/>
                    <Label Text="{Binding MostReadCategory}" TextColor="{StaticResource Primary}" VerticalOptions="Center"/>
                </HorizontalStackLayout>
            </Border>

            <!-- Bar Chart -->
            <Label Text="Distribución por género" Style="{StaticResource SubtitleStyle}"/>
            <GraphicsView x:Name="StatsChart"
                          HeightRequest="250"
                          Drawable="{Binding ChartDrawable}"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>