<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.Views.LibraryPage"
             Title="Mi Biblioteca">

    <VerticalStackLayout Padding="20">
        <Label Text="Mi Biblioteca" FontSize="24" FontAttributes="Bold"/>

    <CollectionView ItemsSource="{Binding Books}">
        <CollectionView.ItemTemplate>
            <DataTemplate>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid ColumnDefinitions="80,*,Auto" ColumnSpacing="10">

                            <!-- Cover Image -->
                            <Image Grid.Column="0" 
               Source="{Binding CoverUrl}"
               Aspect="AspectFill"
               HeightRequest="100"/>

                            <!-- Info -->
                            <StackLayout Grid.Column="1">
                                <Label Text="{Binding Title}"
                   Style="{StaticResource SubtitleStyle}"/>
                                <Label Text="{Binding Author}"/>
                                <Label Text="{Binding Genre}" 
                   Style="{StaticResource CaptionStyle}"/>
                                <Label Text="{Binding IsRead, Converter={StaticResource BoolToReadConverter}}"/>
                            </StackLayout>

                            <!-- Actions -->
                            <StackLayout Grid.Column="2">
                                <Button Text=" " 
                    Command="{Binding Source={x:Reference MainPage}, Path=BindingContext.ViewDetails}"
                    CommandParameter="{Binding .}"/>
                                <Button Text="✓" 
                        Command="{Binding Source={x:Reference MainPage}, Path=BindingContext.MarkAsRead}"
                        CommandParameter="{Binding .}"/>
                            </StackLayout>
                        </Grid>
                    </Border>
                </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <StackLayout>
                <Label Text=" " FontSize="48"/>
                <Label Text="Tu biblioteca está vacía"/>
                <Button Text="Agregar primer libro" Command="{Binding AddBookCommand}"/>
            </StackLayout>
        </CollectionView.EmptyView>
    </CollectionView>
    </VerticalStackLayout>

</ContentPage>