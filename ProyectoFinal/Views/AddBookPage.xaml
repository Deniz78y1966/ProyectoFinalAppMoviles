<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.Views.AddBookPage"
             Title="Agregar Libro">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <Label Text="Agregar Libro" Style="{StaticResource TitleStyle}"/>

            <Label Text="Título *" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding Title}"
                   Placeholder="Título del libro"
                   Style="{StaticResource StandardEntryStyle}"/>

            <Label Text="Autor *" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding Author}"
                   Placeholder="Nombre del autor"
                   Style="{StaticResource StandardEntryStyle}"/>

            <Label Text="ISBN" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding ISBN}"
                   Placeholder="ISBN del libro"
                   Keyboard="Numeric"
                   Style="{StaticResource StandardEntryStyle}"/>

            <Label Text="Año de publicación" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding Year}"
                   Placeholder="Ej: 2023"
                   Keyboard="Numeric"
                   Style="{StaticResource StandardEntryStyle}"/>

            <Label Text="Número de páginas" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding Pages}"
                   Placeholder="Ej: 300"
                   Keyboard="Numeric"
                   Style="{StaticResource StandardEntryStyle}"/>

            <Label Text="Descripción" Style="{StaticResource SubtitleStyle}"/>
            <Editor Text="{Binding Description}"
                    Placeholder="Descripción del libro"
                    HeightRequest="120"/>

            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Guardar"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        WidthRequest="130"/>
                <Button Text="Cancelar"
                        Command="{Binding CancelCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        WidthRequest="130"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
    