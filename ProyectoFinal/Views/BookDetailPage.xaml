<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.Views.BookDetailPage"
             Title="Detalle del Libro">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">

            <!-- Book Cover -->
            <Image Source="{Binding CurrentBook.CoverUrl}"
                   HeightRequest="200"
                   Aspect="AspectFit"
                   HorizontalOptions="Center"/>

            <!-- Calculated properties -->
            <Label Text="{Binding PublishedYearText}"
                   Style="{StaticResource CaptionStyle}"
                   HorizontalOptions="Center"/>
            <Label Text="{Binding PageCountText}"
                   Style="{StaticResource CaptionStyle}"
                   HorizontalOptions="Center"/>
            <Label Text="{Binding RatingText}"
                   Style="{StaticResource CaptionStyle}"
                   HorizontalOptions="Center"/>

            <!-- Title -->
            <Label Text="Título" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding CurrentBook.Title}"
                   Placeholder="Título del libro"
                   Style="{StaticResource StandardEntryStyle}"/>

            <!-- Author -->
            <Label Text="Autor" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding CurrentBook.Author}"
                   Placeholder="Nombre del autor"
                   Style="{StaticResource StandardEntryStyle}"/>

            <!-- ISBN -->
            <Label Text="ISBN" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding CurrentBook.ISBN}"
                   Placeholder="ISBN"
                   Keyboard="Numeric"
                   Style="{StaticResource StandardEntryStyle}"/>

            <!-- Published Year -->
            <Label Text="Año de publicación" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding CurrentBook.PublishedYear}"
                   Placeholder="Año"
                   Keyboard="Numeric"
                   Style="{StaticResource StandardEntryStyle}"/>

            <!-- Page Count -->
            <Label Text="Número de páginas" Style="{StaticResource SubtitleStyle}"/>
            <Entry Text="{Binding CurrentBook.PageCount}"
                   Placeholder="Páginas"
                   Keyboard="Numeric"
                   Style="{StaticResource StandardEntryStyle}"/>

            <!-- Category Picker -->
            <Label Text="Categoría" Style="{StaticResource SubtitleStyle}"/>
            <Picker x:Name="CategoryPicker"
                    Title="Selecciona una categoría">
                <Picker.Items>
                    <x:String>Ficción</x:String>
                    <x:String>No Ficción</x:String>
                    <x:String>Ciencia</x:String>
                    <x:String>Historia</x:String>
                    <x:String>Tecnología</x:String>
                    <x:String>Arte</x:String>
                    <x:String>Otro</x:String>
                </Picker.Items>
            </Picker>

            <!-- Read Status -->
            <HorizontalStackLayout Spacing="10">
                <CheckBox x:Name="ReadCheckBox"/>
                <Label Text="Libro leído"
                       VerticalOptions="Center"/>
            </HorizontalStackLayout>

            <!-- Rating -->
            <Label Text="Calificación" Style="{StaticResource SubtitleStyle}"/>
            <HorizontalStackLayout Spacing="5">
                <Button x:Name="Star1" Text="★" Clicked="OnStarTapped" BackgroundColor="Transparent" TextColor="Gray" FontSize="30"/>
                <Button x:Name="Star2" Text="★" Clicked="OnStarTapped" BackgroundColor="Transparent" TextColor="Gray" FontSize="30"/>
                <Button x:Name="Star3" Text="★" Clicked="OnStarTapped" BackgroundColor="Transparent" TextColor="Gray" FontSize="30"/>
                <Button x:Name="Star4" Text="★" Clicked="OnStarTapped" BackgroundColor="Transparent" TextColor="Gray" FontSize="30"/>
                <Button x:Name="Star5" Text="★" Clicked="OnStarTapped" BackgroundColor="Transparent" TextColor="Gray" FontSize="30"/>
            </HorizontalStackLayout>

            <!-- Description -->
            <Label Text="Descripción" Style="{StaticResource SubtitleStyle}"/>
            <Editor Text="{Binding CurrentBook.Description}"
                    Placeholder="Descripción del libro"
                    HeightRequest="120"/>

            <!-- Action Buttons -->
            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                <Button Text="Guardar"
                        Command="{Binding SaveCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        WidthRequest="100"/>
                <Button Text="Eliminar"
                        Command="{Binding DeleteCommand}"
                        BackgroundColor="#E53935"
                        TextColor="White"
                        WidthRequest="100"/>
                <Button Text="Cancelar"
                        Command="{Binding BackCommand}"
                        Style="{StaticResource SecondaryButtonStyle}"
                        WidthRequest="100"/>
            </HorizontalStackLayout>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>