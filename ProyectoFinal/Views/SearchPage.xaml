<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ProyectoFinal.Views.SearchPage"
             Title="Buscar Libros">

    <VerticalStackLayout Padding="20" Spacing="15">

        <!-- Search bar -->
        <Label Text="Buscar Libros" Style="{StaticResource TitleStyle}"/>

        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10">
            <Entry Grid.Column="0"
                   Text="{Binding SearchQuery}"
                   Placeholder="Título, autor o ISBN..."
                   Style="{StaticResource StandardEntryStyle}"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    Text="Buscar"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    VerticalOptions="Center"/>
        </Grid>

        <!-- Loading indicator -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                           IsVisible="{Binding IsLoading}"
                           Color="{StaticResource Primary}"/>

        <!-- No results message -->
        <Label Text="No se encontraron resultados."
               IsVisible="{Binding NoResults}"
               HorizontalOptions="Center"
               Style="{StaticResource CaptionStyle}"/>

        <!-- Results list -->
        <CollectionView ItemsSource="{Binding Results}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource CardStyle}">
                        <Grid Padding="10" ColumnDefinitions="60,*">

                            <!-- Book cover -->
                            <Image Grid.Column="0"
                                   Source="{Binding ThumbnailUrl}"
                                   WidthRequest="50"
                                   HeightRequest="70"
                                   Aspect="AspectFill"/>

                            <!-- Book info -->
                            <VerticalStackLayout Grid.Column="1" Padding="10,0,0,0" Spacing="4">
                                <Label Text="{Binding Title}"
                                       FontAttributes="Bold"
                                       FontSize="15"
                                       LineBreakMode="TailTruncation"/>
                                <Label Text="{Binding Author}"
                                       FontSize="13"
                                       TextColor="Gray"/>

                                <!-- Tap to see details -->
                                <Button Text="Ver detalles"
                                        FontSize="12"
                                        Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.ViewDetailsCommand}"                                        
                                        CommandParameter="{Binding .}"
                                        BackgroundColor="#5B4FCF"
                                        TextColor="White"
                                        CornerRadius="8"
                                        HorizontalOptions="Start"/>
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </VerticalStackLayout>

</ContentPage>